# Anthropic API Key (required for Claude integration)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama configuration
OLLAMA_HOST=http://localhost:11434

# Default models
CLAUBI_CODE_MODEL=qwen2.5-coder:7b
CLAUBI_REASON_MODEL=llama3.1:8b
CLAUBI_FAST_MODEL=mistral:7b

# Security settings
CLAUBI_AUDIT_LOG=./logs/audit.jsonl
CLAUBI_SANDBOX_ROOT=.
CLAUBI_MAX_SHELL_TIMEOUT_SECS=30

# Log level (trace, debug, info, warn, error)
RUST_LOG=claubi=info
